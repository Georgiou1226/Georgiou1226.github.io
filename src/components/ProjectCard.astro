---
const { project } = Astro.props;
const { title, category, blurb, tier, image, link } = project;
---

<article class="card">
  <div class="card-image">
    {image
      ? <img src={image} alt="" loading="lazy" />
      : <span class="placeholder-label">{category}</span>}
  </div>
  <p class="tag">{category}</p>
  <h3 class="card-title">{title}</h3>
  {tier !== "minor" && <p class="card-blurb">{blurb}</p>}
  {link?.url && (
    <a class="text-link card-link" href={link.url} target={link.type === "onsite" ? "_self" : "_blank"} rel="noopener noreferrer">
      {link.type === "tds" ? "Read the writeup" : link.type === "github" ? "View on GitHub" : "More detail"} &rarr;
    </a>
  )}
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-image {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    background: var(--bg-card);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 2px;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .card-title {
    font-size: 17px;
    line-height: 1.3;
  }

  .card-blurb {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .card-link {
    font-size: 13px;
    margin-top: 2px;
  }
</style>

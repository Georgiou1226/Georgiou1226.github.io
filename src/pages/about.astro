---
import Layout from "../layouts/Layout.astro";

// First-pass copy, written from your CV. Rewrite freely, this is a
// starting point, not your actual voice.
const experience = [
  {
    when: "2026 —",
    what: "Virtual instrumentation intern, Physics of Life, TU Dresden",
  },
  {
    when: "2026 —",
    what: "Contributor, Towards Data Science",
  },
  {
    when: "Jun – Aug 2025",
    what: "ML engineering intern, MLCode — RAG evaluation and benchmarking framework",
  },
  {
    when: "2022 —",
    what: "Volunteer mentor, Computer Science / Robotics workshops",
  },
  {
    when: "2022 – 2023",
    what: "Robotics teacher, Punt Multimèdia",
  },
];
---

<Layout title="About" description="Data science and physical engineering, briefly.">
  <section class="about">
    <h1>About</h1>

    <p>
      I'm a fourth-year student on the CFIS program at Universitat
      Politècnica de Catalunya, reading Data Science &amp; Engineering and
      Physical Engineering at the same time. Most of what's on the work
      page sits somewhere between the two: fluid simulation, machine
      learning applied to physical systems, and the high-performance
      computing needed to make either one run.
    </p>
    <p>
      Right now I'm at TU Dresden's Physics of Life cluster, working on
      virtual instrumentation. Before that, an internship building
      evaluation and benchmarking tools for retrieval-augmented generation
      systems, and before that, teaching robotics and mentoring students
      in programming and 3D printing.
    </p>

    <h2>Experience</h2>
    <ul class="timeline">
      {experience.map((item) => (
        <li>
          <span class="when">{item.when}</span>
          <span class="what">{item.what}</span>
        </li>
      ))}
    </ul>

    <h2>Elsewhere</h2>
    <p>
      <a class="text-link" href="https://github.com/Georgiou1226" target="_blank" rel="noopener noreferrer">GitHub</a>
      &nbsp;·&nbsp;
      <a class="text-link" href="https://www.linkedin.com/in/ferran-alca/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      &nbsp;·&nbsp;
      <a class="text-link" href="mailto:ferran.alia@estudiantat.upc.edu">Email</a>
    </p>
  </section>
</Layout>

<style>
  h1 {
    font-size: 28px;
    margin-bottom: 24px;
  }

  h2 {
    font-size: 18px;
    margin-top: 48px;
    margin-bottom: 16px;
  }

  .about p {
    max-width: 560px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .timeline li {
    display: flex;
    gap: 20px;
    font-size: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .when {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    min-width: 110px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .what {
    color: var(--text);
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects.js";
---

<Layout title="Work" description="Projects across data science, physics, and HPC.">
  <section>
    <h1>Work</h1>
    <p class="intro">
      A working set of academic and personal projects, mostly at the
      intersection of simulation, machine learning, and physics.
    </p>
    <div class="grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</Layout>

<style>
  h1 {
    font-size: 28px;
    margin-bottom: 12px;
  }

  .intro {
    color: var(--text-secondary);
    max-width: 520px;
    margin-bottom: 48px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 32px 24px;
  }
</style>
